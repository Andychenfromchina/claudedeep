# Required
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Search provider — leave SEARCH_PROVIDER unset (or =auto) and the agent
# picks whichever provider you have a key for, in this order:
#   tavily → serper → bing → google_cse
SEARCH_PROVIDER=auto

# tavily — easiest, LLM-optimized, free 1000/mo: https://tavily.com
TAVILY_API_KEY=

# serper — Google results, $50/mo for 50k: https://serper.dev
# SERPER_API_KEY=

# bing — Azure Cognitive Services
# BING_API_KEY=

# google_cse — Custom Search JSON API (needs both key and search-engine ID)
# GOOGLE_API_KEY=
# GOOGLE_CSE_ID=

# Optional: enables --semantic-dedup (text-embedding-3-small, ~$0.02/1M tokens)
# OPENAI_API_KEY=

# Optional: language + prompt-version defaults (CLI flags override)
# DEEP_RESEARCH_LANG=en       # en, zh-CN, ja, …
# DEEP_RESEARCH_PROMPTS=v1
# DEEP_RESEARCH_LOG=pretty    # pretty | json | silent

# Optional: Slack slash-command integration (POST /slack endpoint)
# SLACK_SIGNING_SECRET=
